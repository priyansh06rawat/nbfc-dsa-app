{
  "name": "India Shelter Home Loan",
  "short_name": "India Shelter",
  "description": "Next-generation DSA & Partner Onboarding App with KYC verification for India Shelter Home Loan",
  "start_url": "/index.html",
  "scope": "/",
  "id": "/?source=pwa",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "window-controls-overlay"],
  "orientation": "portrait",
  "background_color": "#FFFFFF",
  "theme_color": "#DE1F26",
  "lang": "en-IN",
  "categories": ["finance", "business"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "scope_extensions": [
    {
      "origin": "*.vercel.app"
    }
  ],
  "file_handlers": [
    {
      "action": "/index.html",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+indiashelter",
      "url": "/?url=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "India Shelter Status",
      "description": "Check application status",
      "tag": "status",
      "template_url": "widget.html",
      "ms_ac_template": "widget.html",
      "data": "widget-data.json",
      "type": "application/json"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
